PORT=5000
NODE_ENV=development
JWT_SECRET=change-this-before-production
MONGO_URI=mongodb+srv://<db-user>:<db-password>@cluster.mongodb.net/solar_app?retryWrites=true&w=majority

# Company admin bootstrap (used on first database startup when no users exist)
ADMIN_NAME=Company Admin
ADMIN_EMAIL=admin@solar.com
ADMIN_PASSWORD=admin123

# Optional flags
ALLOW_DEMO_MODE=true
ALLOW_PUBLIC_REGISTRATION=false

# Email reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Solar Project Management <your-gmail@gmail.com>
