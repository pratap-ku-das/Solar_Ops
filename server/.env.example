PORT=5050
NODE_ENV=development
JWT_SECRET=change-this-before-production
MONGO_URI=mongodb://127.0.0.1:27017/solar_pm

# Company admin bootstrap (used on first database startup when no users exist)
ADMIN_NAME=Company Admin
ADMIN_EMAIL=admin@solar.com
ADMIN_PASSWORD=admin123

# Optional flags
ALLOW_DEMO_MODE=true
ALLOW_PUBLIC_REGISTRATION=false

# Email reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@pragatiecosolar.in
SMTP_PASS=your-app-password
MAIL_FROM=Solar Project Management <info@pragatiecosolar.in>